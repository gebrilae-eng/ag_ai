# Normalize line endings for all text files
* text=auto eol=lf

# Markdown files
*.md text eol=lf

# Python files
*.py text eol=lf

# JSON files
*.json text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell
*.ps1 text eol=crlf

# Binary files - no conversion
*.png binary
*.jpg binary
*.gif binary
*.zip binary
*.exe binary
